# Copy to terraform.tfvars (gitignored) and fill in. No SECRETS belong here —
# per-user BYOK keys + the OAuth client/cookie secret values live in Secret
# Manager (set out-of-band). This file holds only non-secret config.

project_id = "your-dev-project-id"
region     = "us-central1"

# After the first image build/push, set the real image:
image = "us-central1-docker.pkg.dev/your-dev-project-id/career-engine-dev-images/app:latest"

# Web OIDC login (Streamlit st.login). Create a Google OAuth 2.0 Web client in the
# Console; put its client ID here. The redirect URI is derived from custom_domain
# (default: career-engine.bitcrafty.cloud/_stcore/oauth2callback).
auth_client_id = "your-oauth-client-id.apps.googleusercontent.com"
# auth_redirect_uri was removed — it is now derived from custom_domain in main.tf.

# Custom domain + Cloudflare DNS.
# cloudflare_zone_id is not sensitive — safe to set here.
# cloudflare_api_token and google_domain_verification_txt are SENSITIVE — set via
# environment variables (TF_VAR_cloudflare_api_token, TF_VAR_google_domain_verification_txt)
# or a secrets manager; never put them here.
cloudflare_zone_id = "your-cloudflare-zone-id"
# custom_domain defaults to "career-engine.bitcrafty.cloud"; override here if needed:
# custom_domain = "career-engine.example.com"

# Phase 2 bootstrap only — paste the output of `terraform output domain_mapping_resource_records`
# here after the first apply, then apply again to create the Cloudflare A/AAAA records.
# Leave empty (the default) on the first apply.
# dns_resource_records = [
#   { type = "A",    rrdata = "216.239.32.21" },
#   { type = "AAAA", rrdata = "2001:4860:4802:32::15" },
# ]
