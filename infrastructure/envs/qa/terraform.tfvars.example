# Copy to terraform.tfvars (gitignored) for LOCAL applies, or let deploy.yml pass these
# via TF_VAR_* in CI. No secrets here — BYOK keys live in Secret Manager (set at runtime).

# The SAME project as dev (qa is a second Cloud Run service in it).
project_id = "gen-lang-client-0513394764"
region     = "us-central1"

# Set after the first image build/push (deploy.yml sets this automatically in CI):
image = "us-central1-docker.pkg.dev/gen-lang-client-0513394764/career-engine-qa-images/app:latest"

# Firebase project id (token audience). Leave empty to use project_id (Firebase enabled on
# the same GCP project). Set only if the Firebase project differs from the GCP project.
# firebase_project_id = ""
