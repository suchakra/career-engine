# Copy to terraform.tfvars (gitignored) and fill in. No secrets belong here —
# per-user BYOK keys live in Secret Manager, created at runtime by the app.

project_id = "your-prod-project-id"
region     = "us-central1"

# REQUIRED for prod (no default; the hello placeholder is rejected):
image = "us-central1-docker.pkg.dev/your-prod-project-id/career-engine-prod-images/app:latest"
