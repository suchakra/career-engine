# CareerEngine — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Gemini / Google AI ─────────────────────────────────────────────────────────
# Platform-managed key (Free Mode). Used only for the managed-key tier.
# Users in BYOK Mode supply their own key via the UI; it is stored in Secret
# Manager (id: ce-key-{user_id}) and NEVER written here or to Firestore.
GEMINI_API_KEY=your-gemini-api-key-here

# ── Google Cloud project ────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Access mode ─────────────────────────────────────────────────────────────────
# FREE  → platform manages the Gemini key (Flash/Flash-Lite only)
# BYOK  → user key fetched from Secret Manager at runtime
ACCESS_MODE=FREE

# ── Firebase / Identity Platform ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Developer escape hatch (local dev + offline testing ONLY) ──────────────────
# Set these to bypass Identity Platform auth in local dev.
# Both must be set together; neither is ever used in production.
DEV_USER_ID=
DEV_GEMINI_KEY=

# ── Application ─────────────────────────────────────────────────────────────────
# Override the default app name used to namespace ADK sessions/Firestore docs.
APP_NAME=career-engine
