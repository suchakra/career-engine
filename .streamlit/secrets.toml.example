# CareerEngine — Streamlit native OIDC auth config.
#
# Copy to .streamlit/secrets.toml (GIT-IGNORED — contains secrets) and fill in.
# Create the OAuth client in Google Cloud Console → APIs & Services → Credentials
# → "OAuth client ID" (type: Web application). Add BOTH redirect URIs:
#   - local:      http://localhost:8501/oauth2callback
#   - deployed:   https://<your-cloud-run-url>/oauth2callback
#
# In production (Cloud Run) these values are injected as env vars and the
# container's entrypoint (docker-entrypoint.sh) writes this file at startup —
# client_secret + cookie_secret should come from Secret Manager, never committed.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "generate-a-long-random-string"       # e.g. python -c "import secrets;print(secrets.token_hex(32))"
client_id = "your-oauth-client-id.apps.googleusercontent.com"
client_secret = "your-oauth-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
