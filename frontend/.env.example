# CareerEngine frontend — public client configuration.
#
# NOTE: every NEXT_PUBLIC_* value below is PUBLIC client config that ships in the
# browser bundle. These are NOT secrets. The Firebase "API key" is a public
# project identifier, not a credential — access is controlled by Firebase Auth
# rules and the backend verifying the ID token, NOT by keeping this value hidden.
# Do NOT put any real secret (BYOK Gemini key, service-account key, etc.) here.
#
# Copy to `.env.local` and fill with your Firebase web-app config. The project id
# MUST match the backend FIREBASE_PROJECT_ID / GCP_PROJECT_ID.

# Firebase Web SDK (public app config, Google sign-in provider).
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# FastAPI backend base URL. Dev default is the local Cloud Run-style port.
# Real CORS / allowed-origin wiring is handled in slice 10.7 — not here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
